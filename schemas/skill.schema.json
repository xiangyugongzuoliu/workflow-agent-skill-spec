{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xiangyugongzuoliu/workflow-agent-skill-spec/schemas/skill.schema.json",
  "title": "Workflow Agent Skill Metadata",
  "description": "SKILL.md frontmatter 的机器可验证投影。Markdown 正文仍按 docs/skill-file.md 检查。",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "稳定 Skill 名称，使用小写字母、数字和连字符。"
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 500,
      "description": "触发说明，必须写清何时使用和何时不使用。"
    },
    "license": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    },
    "compatibility": {
      "type": "string",
      "maxLength": 600,
      "description": "可选。记录平台、工具或运行能力要求。"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
